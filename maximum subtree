class Solution {
public:
    int maximum = INT_MIN;
    
    int calculate(Node* root){
        if(root==NULL) 
        return 0;
        
        int left = calculate(root->left);
        int right = calculate(root->right);
        
        int sum = left + right + root->data;
        maximum = max(maximum, sum);
        return sum;
        
    }
    int maxSubtreeSum(Node* root) {
        calculate(root);
        return maximum;

    
    }
};
