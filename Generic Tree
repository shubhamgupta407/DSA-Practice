#include <iostream>
#include<bits/stdc++.h>
using namespace std;


class Tree{

public:
    int val;
    vector<Tree*>children;
    
    Tree(int val){
        this->val=val;
    }
};

void print(Tree* root){
    if(root == NULL) return;
    
    cout<<root->val<<endl;
    
    for(auto c: root->children){
        cout<<c->val<<" ";
    }
    
    cout<<endl;
    
    for(auto x: root->children){
        print(x);
    }
}




int main() {
    
    Tree* root = new Tree(9);
    
    Tree* c1= new Tree(32);
    Tree* c2= new Tree(16);
    
    root->children.push_back(c1);
    root->children.push_back(c2);
    
    Tree* d1= new Tree(6);
    Tree* d2= new Tree(3);
    Tree* d3= new Tree(4);
    Tree* d4= new Tree(5);
    Tree* d5= new Tree(2);
    
    c1->children.push_back(d1);
    c1->children.push_back(d2);
    c1->children.push_back(d3);
    c1->children.push_back(d4);
